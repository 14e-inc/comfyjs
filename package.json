{
  "name": "@hebronwatson/comfyjs",
  "version": "0.1.0",
  "description": "A comfortable JavaScript utility library",
  "author": "Hebron Watson",
  "license": "MIT",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "rollup": "^4.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hebronwatson/comfyjs.git"
  },
  "bugs": {
    "url": "https://github.com/hebronwatson/comfyjs/issues"
  },
  "homepage": "https://github.com/hebronwatson/comfyjs#readme",
  "keywords": []
}
