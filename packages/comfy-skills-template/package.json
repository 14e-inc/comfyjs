{
  "name": "@comfy/skills-template",
  "version": "0.1.0",
  "description": "Template package for a single-skill MCP-ready module (AgentSkills.io-compliant, skills-npm discovery)",
  "author": "14e Inc.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "comfy-skill": "./dist/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./skills/*": "./skills/*"
  },
  "files": [
    "dist",
    "skills",
    "AGENTS.md"
  ],
  "agentskills": {
    "skills": [
      { "name": "comfy", "path": "./skills/comfy" }
    ]
  },
  "_templateFields": {
    "_note": "Field paths that the Yeoman generator substitutes via EJS. Kept out of live JSON fields so pnpm install stays valid. See AGENTS.md §Generator Contract.",
    "name": "<%= scope %>/<%= packageSlug %>",
    "description": "<%= description %>",
    "author": "<%= authorName %> <<%= authorEmail %>>",
    "agentskills.skills[0].name": "<%= skillSlug %>",
    "agentskills.skills[0].path": "./skills/<%= skillSlug %>"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:watch": "rollup -c rollup.config.mjs --watch",
    "clean": "rm -rf dist coverage",
    "prebuild": "pnpm run clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "rollup": "^4.0.0",
    "tslib": "^2.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "skill",
    "agentskills",
    "mcp",
    "model-context-protocol",
    "template",
    "comfy-skills"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hebronwatson/comfyjs.git",
    "directory": "packages/comfy-skills-template"
  },
  "bugs": {
    "url": "https://github.com/hebronwatson/comfyjs/issues"
  },
  "homepage": "https://github.com/hebronwatson/comfyjs/tree/main/packages/comfy-skills-template#readme"
}
