import { describe, it, expect } from 'vitest';
import { <%= skillCamel %>Skill } from '../<%= skillSlug %>';

describe('<%= skillCamel %>Skill', () => {
  it('has the correct name', () => {
    expect(<%= skillCamel %>Skill.name).toBe('<%= skillSlug %>');
  });

  it('has the correct description', () => {
    expect(<%= skillCamel %>Skill.description).toBe('<%= skillDescription %>');
  });

  it('execute returns a result with a timestamp', async () => {
    const output = await <%= skillCamel %>Skill.execute({ message: 'test' });
    expect(output.result).toBe('test');
    expect(output.timestamp).toMatch(/^\d{4}-\d{2}-\d{2}T/);
  });
});
